# Generated files
assets_data.h
assets.sso
resource.o

# Risky executables
*.dll
*.so
*.dylib

# Backup folders
backup_risky/

# Large binary files (over 1MB)
# Note: Kalau file di lib/ atau include/ masih ilang, 
# hapus dua baris di bawah ini:
*.a
*.lib

# Security sensitive
*.pem
*.key
*.crt

# Generated files
include/assets_data.h

# OS files
.DS_Store
Thumbs.db

# Pengecualian folder lib
!lib/
!lib/*.a
!lib/*.lib
!lib/*.dll

# TETEP IGNORE folder compiler kalau masih ada
lib/gcc/
lib/bfd-plugins/